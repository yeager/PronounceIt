#: pronounceit/scoring/feedback.py
msgid "Utmärkt! Ditt uttal är mycket nära referensen. Bra jobbat!"
msgstr "Utmärkt! Ditt uttal är mycket nära referensen. Bra jobbat!"

#: pronounceit/scoring/feedback.py
msgid "Bra uttal! Några små justeringar kan göra det ännu bättre."
msgstr "Bra uttal! Några små justeringar kan göra det ännu bättre."

#: pronounceit/scoring/feedback.py
msgid "Godkänt uttal. Fortsätt öva för att förbättra precisionen."
msgstr "Godkänt uttal. Fortsätt öva för att förbättra precisionen."

#: pronounceit/scoring/feedback.py
msgid "Uttalet behöver mer övning. Lyssna noga på referensen och försök igen."
msgstr "Uttalet behöver mer övning. Lyssna noga på referensen och försök igen."

#: pronounceit/scoring/feedback.py
msgid "Försök igen! Lyssna på referensen och fokusera på ett ljud i taget."
msgstr "Försök igen! Lyssna på referensen och fokusera på ett ljud i taget."

#: pronounceit/scoring/feedback.py
msgid "Spektral analys visar att ljudet skiljer sig från referensen. Försök lyssna noga på referensen och imitera."
msgstr "Spektral analys visar att ljudet skiljer sig från referensen. Försök lyssna noga på referensen och imitera."

#: pronounceit/scoring/feedback.py
msgid "Ljudet är nära referensen men kan förbättras. Fokusera på artikulationens precision."
msgstr "Ljudet är nära referensen men kan förbättras. Fokusera på artikulationens precision."

#: pronounceit/scoring/feedback.py
msgid "Tonhöjdsmönstret avviker markant. Var uppmärksam på intonationen och betoningen."
msgstr "Tonhöjdsmönstret avviker markant. Var uppmärksam på intonationen och betoningen."

#: pronounceit/scoring/feedback.py
msgid "Intonationen kan förbättras. Lyssna på melodin i referensuttalet."
msgstr "Intonationen kan förbättras. Lyssna på melodin i referensuttalet."

#: pronounceit/scoring/feedback.py
msgid "Vokalerna behöver justeras. Kontrollera tungans och läpparnas position."
msgstr "Vokalerna behöver justeras. Kontrollera tungans och läpparnas position."

#: pronounceit/scoring/feedback.py
msgid "Vokalerna är nära men kan finslipas. Tänk på munöppning och tungposition."
msgstr "Vokalerna är nära men kan finslipas. Tänk på munöppning och tungposition."

#: pronounceit/scoring/feedback.py
msgid "Svenska har många vokaler. Tänk särskilt på skillnaden mellan lång och kort vokal, t.ex. 'hus' /hʉːs/ vs 'huss' /hɵs/."
msgstr "Svenska har många vokaler. Tänk särskilt på skillnaden mellan lång och kort vokal, t.ex. 'hus' /hʉːs/ vs 'huss' /hɵs/."

#: pronounceit/scoring/feedback.py
msgid "Svenskan har ordaccenter (accent 1 och accent 2). Tonhöjdsmönstret är viktigt för ordets betydelse."
msgstr "Svenskan har ordaccenter (accent 1 och accent 2). Tonhöjdsmönstret är viktigt för ordets betydelse."

#: pronounceit/scoring/feedback.py
msgid "Tyska vokaler har tydlig skillnad mellan spända och ospända. T.ex. /iː/ i 'Miete' vs /ɪ/ i 'Mitte'."
msgstr "Tyska vokaler har tydlig skillnad mellan spända och ospända. T.ex. /iː/ i 'Miete' vs /ɪ/ i 'Mitte'."

#: pronounceit/scoring/feedback.py
msgid "Franska nasalvokaler kräver att luft släpps genom näsan. Öva med /ɑ̃/ i 'dans' och /ɛ̃/ i 'vin'."
msgstr "Franska nasalvokaler kräver att luft släpps genom näsan. Öva med /ɑ̃/ i 'dans' och /ɛ̃/ i 'vin'."
